# 로컬 개발용. 이 파일을 복사해 .env 로 만들고 값을 채우세요.
# .env 는 git 에 올라가지 않습니다(.gitignore).
#
# 로그인 없음 — URL에 ?admin=<이 값> 을 붙이면 매니저 화면(API키 관리)이 보인다.
# 비워두면 매니저 화면 자체가 아무도 못 봄(항상 팀원 모드).
# 값은 무작위 문자열 권장(예: python3 -c "import secrets;print(secrets.token_urlsafe(18))").
MANAGER_TOKEN=

# Supabase 를 쓰려면 아래 두 값을 채우세요.
# 비워두면 자동으로 로컬 JSON(local_data.json) 모드로 동작합니다.

SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# 썸네일 확장: 웹앱은 "확장이 설치돼 있는지"만 확인(PING)한다(실제 추출은 확장 팝업에서 직접 클릭).
# CHROME_EXTENSION_ID 는 extension/manifest.json 의 key 로 고정된 값(기본값이 app.py에 내장되어 있어 비워둬도 됨).
# EXTENSION_INSTALL_URL 은 설치 안내에 표시할 웹스토어 링크(선택).
CHROME_EXTENSION_ID=
EXTENSION_INSTALL_URL=
