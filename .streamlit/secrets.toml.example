# 배포(Streamlit Community Cloud)용 시크릿.
# 배포 화면의 Settings > Secrets 에 아래 내용을 붙여넣으세요.
# 로컬에서 쓰려면 이 파일을 secrets.toml 로 복사해 값을 채우세요(.gitignore 됨).

# 로그인 없음 — 배포된 URL 뒤에 ?admin=<이 값> 을 붙인 사람만 매니저 화면(API키 관리)을 본다.
MANAGER_TOKEN = "무작위-문자열-여기에"

SUPABASE_URL = "https://xxxx.supabase.co"
SUPABASE_SERVICE_KEY = "eyJ...service_role...key"

# 썸네일 확장 설치 확인(PING)용. ID는 extension/manifest.json 의 key로 고정됨.
CHROME_EXTENSION_ID = "algnnfjoiiepjinfalghfnmmpjedehdg"
EXTENSION_INSTALL_URL = "https://chromewebstore.google.com/..."
