{
  "manifest_version": 3,
  "name": "쿠팡 썸네일 다운로더 (팀 내부용)",
  "version": "1.1.0",
  "description": "쿠팡 상품 페이지에서 썸네일 후보를 추출해 하나를 골라 다운로드합니다.",
  "key": "",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting"
  ],
  "host_permissions": [
    "https://*.coupang.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "https://*.streamlit.app/*"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "쿠팡 썸네일 다운로더"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.coupang.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}